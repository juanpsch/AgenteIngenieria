# === Proveedor LLM (configurable) ===
# Proveedor a usar: "openai" (directo) o "claude"/otros (vía LiteLLM).
LLM_PROVIDER=openai
# Modelo. Ej OpenAI: gpt-4o, gpt-4o-mini. Ej Claude (LiteLLM): claude-opus-4-8, claude-sonnet-4-6.
LLM_MODEL=gpt-4o
# Modelo barato para tareas simples (parser). Si vacío, usa LLM_MODEL.
LLM_MODEL_FAST=gpt-4o-mini
# Claves (cargá la del proveedor elegido)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Robustez del LLM: timeout por llamada (seg) y reintentos con backoff ante fallas transitorias.
LLM_TIMEOUT=90
LLM_RETRIES=2

# === API ===
# Tamaño máximo de archivo subido (MB). Se rechaza con 413 si se supera.
MAX_UPLOAD_MB=25

# === Base de datos (Fase 0 = local) ===
# local = checkpointer SQLite en disco; neon = Postgres (Fase 4)
DB_MODE=local
# Ruta del SQLite local (Fase 0). Gitignored.
LOCAL_DB_PATH=local_state/qa_ingenieria.sqlite
# Connection string Neon (Fase 4, no usar en sandbox)
DATABASE_URL=

# === CAD ===
# Ruta al ejecutable ODA File Converter para leer DWG (opcional; degrada con gracia si falta).
ODA_CONVERTER_PATH=

# === Similitud por embeddings (Cotejar Fase C) ===
# Proveedor: "local" = CLIP vía open-clip-torch (descarga pesos la 1ª vez). Si no está
# disponible, el cotejo degrada con gracia (score=None) y sigue por reglas.
EMBED_PROVIDER=local
EMBED_MODEL=ViT-B-32
EMBED_PRETRAINED=laion2b_s34b_b79k
# El modelo se carga OFFLINE (desde la cache local) para no colgarse pingeando HuggingFace Hub.
# Solo para la DESCARGA inicial en una máquina nueva: exportá EMBED_ALLOW_DOWNLOAD=1 una vez.
EMBED_ALLOW_DOWNLOAD=
# Umbrales del score de similitud (0–100). >=APPROVAL -> válido; [REVISION,APPROVAL) -> revisión; <REVISION -> inválido.
APPROVAL_THRESHOLD=96
REVISION_THRESHOLD=85
# Madurez del template por nº de referencias: < CALIBRATING_MIN = solo_reglas;
# [CALIBRATING_MIN, CALIBRATED_MIN) = calibrando (score informativo); >= CALIBRATED_MIN = calibrado (score decide).
CALIBRATING_MIN=2
CALIBRATED_MIN=5
# Nº de pares top-k para promediar el coseno candidato×referencias.
SIM_TOPK=3
# Pesos del score: la zona de identidad (encabezado/rótulo) pesa más que la página completa.
SIM_WEIGHT_CAJETIN=0.7
SIM_WEIGHT_PAGINA=0.3
# Margen (fracción de página) alrededor de la zona al recortar: absorbe pequeños desvíos de
# posición del cajetín/encabezado entre documentos. Mismo margen en candidato y referencias.
SIM_ZONE_PAD=0.05
# Páginas a renderizar/embeber por documento (para zonas en páginas > 1).
SIM_MAX_PAGES=6
# Nota: con template "calibrado", los umbrales se auto-estiman de la distribución de sus
# ejemplos (media−1σ / media−2.5σ). APPROVAL/REVISION_THRESHOLD son el fallback si no alcanza.

# === OCR (opcional) para texto que vive solo en la imagen (escaneos, cajetines rasterizados) ===
# Proveedor: "tesseract" (local, en tu máquina/contenedor) o "none" (desactivado -> cae al LLM).
# Requiere el binario Tesseract instalado (Windows: build UB Mannheim; Linux: apt tesseract-ocr).
OCR_PROVIDER=tesseract
OCR_LANG=spa+eng
OCR_DPI=220
OCR_MIN_CONF=40
# Si Tesseract no está en el PATH, apuntá al binario (Windows ej: C:\Program Files\Tesseract-OCR\tesseract.exe)
TESSERACT_CMD=

# === Revisión de contenido (Fase 1) ===
# Páginas que cubre la REVISIÓN (independiente del cap del gate SIM_MAX_PAGES). 0 = todas. La revisión
# corre como 2º paso (con progreso), así que puede permitirse más. El texto ya cubre todo el doc.
REVISION_MAX_PAGES=0
# Cuántas páginas muestrear para medir legibilidad (nitidez/OCR): portada + equiespaciadas + última.
REVISION_LEG_SAMPLES=6
# Tier 3 (observación VLM): 1 = corre si el template/normas declaran criterios; 0 = desactivado.
# Hace una llamada LLM de visión (en el 2º paso, con progreso). Las observaciones nunca bloquean solas.
REVISION_VLM=1

# === Infra real (Fase 4 en adelante; sin uso en sandbox) ===
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
AGENT_INBOUND_ADDRESS=
AGENT_FROM_NAME=QA Ingeniería - Empresa
GOOGLE_CREDENTIALS_JSON=
DRIVE_ROOT_FOLDER_ID=
SHEET_MAESTRO_ID=
CRON_SECRET=
APP_BASE_URL=
